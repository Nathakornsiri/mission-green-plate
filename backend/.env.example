# ─── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # development | production

# ─── Security ──────────────────────────────────────────────────
# Generate a strong random secret for production:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=greenplate_mission_secret_change_in_production

# ─── CORS ──────────────────────────────────────────────────────
# In production, set this to your Vercel / Netlify frontend URL
# Leave empty if using monorepo mode (Express serves the static build)
FRONTEND_URL=http://localhost:5173

# ─── Demo Mode ─────────────────────────────────────────────────
DEMO_MODE=true
# Secret required to call POST /api/demo/reset (reset seed data)
DEMO_RESET_SECRET=reset_greenplate_demo
